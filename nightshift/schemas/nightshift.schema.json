{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle",
    "status",
    "fixes",
    "logged_issues",
    "categories",
    "files_touched",
    "tests_run",
    "notes"
  ],
  "properties": {
    "cycle": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "log_only",
        "no_changes",
        "failed"
      ]
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "category",
          "impact",
          "files",
          "commit"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "Security",
              "Error Handling",
              "Tests",
              "A11y",
              "Code Quality",
              "Performance",
              "Polish"
            ]
          },
          "impact": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "commit": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "logged_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "category",
          "severity",
          "files",
          "reason"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "Security",
              "Error Handling",
              "Tests",
              "A11y",
              "Code Quality",
              "Performance",
              "Polish"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Security",
          "Error Handling",
          "Tests",
          "A11y",
          "Code Quality",
          "Performance",
          "Polish"
        ]
      }
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
